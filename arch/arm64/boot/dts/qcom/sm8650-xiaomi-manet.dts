/dts-v1/;

#include <dt-bindings/pinctrl/qcom,pmic-gpio.h>
#include <dt-bindings/regulator/qcom,rpmh-regulator.h>
#include "sm8650.dtsi"
#include "pm8550.dtsi"
#define PMK8550VE_SID 8
#include "pm8550ve.dtsi"
#include "pm8550vs.dtsi"
#include "pmk8550.dtsi"
#include "pmr735d_a.dtsi"

/delete-node/ &hwfence_shbuf;
/delete-node/ &rmtfs_mem;

#define ENABLE_SIMPLEFB true 

/ {
        model = "Xiaomi Redmi K70 Pro";
        compatible = "xiaomi,manet", "qcom,sm8650";

        chosen {
                #address-cells = <2>;
                #size-cells = <2>;
                ranges;

                bootargs = "console=tty0 clk_ignore_unused PMOS_NO_OUTPUT_REDIRECT";

#if ENABLE_SIMPLEFB
                simplefb: framebuffer@fc400000 {
                        compatible = "simple-framebuffer";
                        reg = <0x0 0xfc400000 0x0 0x2b00000>;
                        width = <1440>;
                        height = <3200>;
                        stride = <(1440 * 4)>;
                        format = "a8r8g8b8";
                };
#endif
        };

        reserved-memory {
                chipinfo_region@81cf4000 {
                    reg = <0x0 0x81cf4000 0x0 0x1000>;
                    no-map;
                };

                mpss_dsm_region@86b00000 {
                    reg = <0x0 0x86b00000 0x0 0x4900000>;
                    no-map;
                };

                xbl_ramdump_region@84800000 {
                    reg = <0x0 0x84800000 0x0 0x200000>;
                    no-map;
                };

                mpss_dsm_region_2@8b400000 {
                    reg = <0x0 0x8b400000 0x0 0x800000>;
                    no-map;
                };

                mpss_region@8bc00000 {
                    reg = <0x0 0x8bc00000 0x0 0xf400000>;
                    no-map;
                };

                adspslpi_region@9df00000 {
                    reg = <0x0 0x9df00000 0x0 0x4080000>;
                    no-map;
                };

                hwfence-shmem {
                    reg = <0x0 0xff100000 0x0 0x2dd000>;
                    no-map;
                };

                /* Hack for simplefb */
                splash_region {
                    reg = <0x0 0xfc400000 0x0 0x2b00000>;
                    no-map;
                };

                rmtfs_mem: rmtfs@ea100000 {
                    compatible = "qcom,rmtfs-mem";
                    reg = <0x0 0xea100000 0x0 0x400000>;
                    no-map;

                    qcom,client-id = <1>;
                    qcom,vmid = <QCOM_SCM_VMID_MSS_MSA>;
                };
        };
};

&sleep_clk {
	clock-frequency = <32000>;
};

&tlmm {
	gpio-reserved-ranges = <8 4>, <24 8>, <74 1>;
};

