#if ENABLE_SIMPLEFB
&dispcc {
	status = "disabled";
};
#endif

&i2c_master_hub_0 {
	status = "okay";
};

&i2c_hub_5 {
	status = "okay";

	ti_eusb2_repeater: repeater@3e {
		#phy-cells = <0>;
		compatible = "ti,eusb2-repeater";
		reg = <0x3e>;
		vdd18-supply = <&vreg_l15b_1p8>;
		vdd3-supply = <&vreg_l5b_3p1>;
		reset-gpio = <&pm8550vs_c_gpios 4 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&eusb2_reset_ctrl>;
		qcom,param-host-override-seq = <0x00 0x50 0x06 0x51 0x01 0x52 0x07 0x53 0x03 0x54 0x00 0x55 0x00 0x56 0x04 0x57 0x02 0x58 0x03 0x59 0x01 0x5a 0x02 0x5b>;
		qcom,param-override-seq = <0x00 0x50 0x0f 0x51 0x04 0x52 0x07 0x53 0x03 0x54 0x01 0x55 0x00 0x56 0x07 0x57 0x02 0x58 0x03 0x59 0x01 0x5a 0x02 0x5b>;
	};
};

&pm8550vs_c_gpios {
	eusb2_reset_ctrl: eusb2-reset-ctrl-default {
		pins = "gpio4";
		function = PMIC_GPIO_FUNC_NORMAL;
		input-enable;
		output-enable;
		bias-disable;
		power-source = <1>;
		qcom,drive-strength = <PMIC_GPIO_STRENGTH_MED>;
	};
};

&usb_1 {
	/* USB 2.0 only for now */
	qcom,select-utmi-as-pipe-clk;
	status = "okay";
};

&usb_1_dwc3 {
	dr_mode = "peripheral";
	maximum-speed = "high-speed";
	/* Remove USB3 phy */
	phys = <&usb_1_hsphy>;
	phy-names = "usb2-phy";
};

&usb_1_hsphy {
	vdd-supply = <&vreg_l1i>;
	vdda12-supply = <&vreg_l3i>;

	phys = <&ti_eusb2_repeater>;

	status = "okay";
};

&usb_dp_qmpphy {
	vdda-phy-supply = <&vreg_l3i>;
	vdda-pll-supply = <&vreg_l3g>;

	status = "okay";
};

&xo_board {
	clock-frequency = <76800000>;
};
